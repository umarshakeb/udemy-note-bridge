{
  "manifest_version": 3,
  "name": "Python Note Bridge",
  "version": "1.1",
  "permissions": ["activeTab", "scripting", "storage"], 
  "host_permissions": ["http://localhost:5000/*","https://www.udemy.com/*"],
  "action": { "default_popup": "popup.html" },
  "options_page": "options.html",
  "icons":{
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}